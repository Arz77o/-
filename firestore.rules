rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'abdouarbouz56@gmail.com';
    }

    match /orders/{document} {
      allow read: if request.auth != null && request.auth.token.email == 'abdouarbouz56@gmail.com';
      allow create: if true;
      allow update: if request.auth != null && request.auth.token.email == 'abdouarbouz56@gmail.com';
      allow delete: if request.auth != null && request.auth.token.email == 'abdouarbouz56@gmail.com';
    }
  }
}
