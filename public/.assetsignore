# Cloudflare Pages Assets Ignore File
# This file tells Cloudflare Pages which files to exclude from deployment

# Version control
.git
.gitignore

# Dependencies
node_modules
.npm
.yarn
.pnpm-store

# Environment files
.env
.env.*
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode
.idea
*.swp
*.swo
*~

# Documentation
README.md
LICENSE
CHANGELOG.md
*.md

# Build artifacts not needed in production
dist
.tmp
.temp
.cache

# Test files
*.test.*
*.spec.*
coverage
.nyc_output