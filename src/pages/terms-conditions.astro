---
import BaseLayout from '../layouts/BaseLayout.astro';
const currentPath = '/terms-conditions';
---

<BaseLayout title="الشروط والأحكام - Matjari-متجري" currentPath={currentPath}>
  <div class="min-h-screen bg-gray-50 py-8 md:py-12" dir="rtl">
    <div class="max-w-3xl mx-auto px-4">
      <div class="flex items-center gap-4 mb-8">
        <a
          href="/"
          class="w-10 h-10 flex items-center justify-center rounded-full bg-white border border-gray-100 shadow-sm hover:bg-gray-100 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-700"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">الشروط والأحكام</h1>
      </div>

      <div class="bg-white rounded-3xl p-6 md:p-10 shadow-sm border border-gray-100">
        <div class="flex items-center gap-3 mb-6 pb-6 border-b border-gray-100">
          <div class="w-12 h-12 rounded-2xl bg-emerald-50 flex items-center justify-center text-emerald-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <div>
            <p class="text-sm text-gray-500">اتفاقية استخدام الموقع</p>
            <h2 class="text-xl font-bold text-gray-900">الشروط والأحكام العامة للمتجر</h2>
          </div>
        </div>

        <div class="space-y-8 text-gray-700 leading-relaxed">
          <p class="text-gray-600">
            مرحباً بكم في متجرنا الإلكتروني. بدخولكم واستخدامكم للموقع أو تقديم طلب شراء، فإنكم توافقون على الالتزام بالشروط والأحكام التالية. يرجى قراءتها بعناية قبل المتابعة.
          </p>

          <section>
            <h3 class="text-lg font-bold text-gray-950 mb-3 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              شروط الشراء وتأكيد الطلب
            </h3>
            <p class="text-gray-600 pr-4">
              عند تقديم طلب من خلال المتجر، فإنك توافق على تزويدنا بمعلومات صحيحة ودقيقة، بما في ذلك الاسم الكامل ورقم الهاتف وعنوان التوصيل بدقة. سيقوم فريق خدمة العملاء بالاتصال بك هاتفياً لتأكيد الطلب وعنوان التوصيل قبل إرسال الشحنة.
            </p>
          </section>

          <section>
            <h3 class="text-lg font-bold text-gray-950 mb-3 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              الدفع عند الاستلام (COD)
            </h3>
            <p class="text-gray-600 pr-4">
              نعتمد طريقة الدفع عند الاستلام كوسيلة دفع رئيسية وآمنة لعملائنا في الجزائر. يقوم العميل بدفع قيمة المنتج وتكلفة الشحن نقداً لسائق التوصيل فور استلام المنتج ومعاينته.
            </p>
          </section>

          <section>
            <h3 class="text-lg font-bold text-gray-950 mb-3 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              خدمة الشحن والتوصيل
            </h3>
            <p class="text-gray-600 pr-4">
              نوفر خدمة التوصيل السريع إلى مختلف الولايات. تختلف تكلفة الشحن ومدة التوصيل بحسب الولاية المحددة في الطلب. نحن نبذل قصارى جهدنا لتسليم الطلبات في أسرع وقت ممكن، ولكن قد تحدث بعض التأخيرات الاستثنائية الخارجة عن إرادتنا.
            </p>
          </section>

          <section>
            <h3 class="text-lg font-bold text-gray-950 mb-3 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              حقوق الملكية الفكرية
            </h3>
            <p class="text-gray-600 pr-4">
              جميع المحتويات المتوفرة على هذا الموقع، بما في ذلك التصاميم، الصور، النصوص، الشعارات، والبرمجيات، هي ملك للمتجر ومحمية بموجب قوانين حماية الملكية الفكرية. لا يُسمح بنسخ أو استخدام أي جزء منها للأغراض التجارية دون موافقتنا المكتوبة مسبقاً.
            </p>
          </section>

          <section>
            <h3 class="text-lg font-bold text-gray-950 mb-3 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              سرية وأمان البيانات
            </h3>
            <p class="text-gray-600 pr-4">
              نحن ملتزمون بحماية خصوصيتك وسرية بياناتك الشخصية. لن نقوم بمشاركة أو بيع معلومات الاتصال الخاصة بك مع أي طرف ثالث، ويقتصر استخدامها على تأكيد وتوصيل طلباتك وتحسين خدماتنا المقدمة لك.
            </p>
          </section>
        </div>

        <div class="mt-10 pt-8 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-4 bg-gray-50 -mx-6 -mb-6 md:-mx-10 md:-mb-10 p-6 md:p-8 rounded-b-3xl">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600"><path d="M2 12V7a5 5 0 0 1 5-5h10a5 5 0 0 1 5 5v5"/><path d="M22 17v3a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-3"/><path d="M12 7v10"/><path d="M2 17h20"/></svg>
            <div>
              <p class="font-bold text-gray-900 text-sm">التزام بالشفافية والوضوح</p>
              <p class="text-xs text-gray-500">تحديث مستمر للشروط لضمان حقوق الجميع</p>
            </div>
          </div>
          <a href="/" class="bg-emerald-600 hover:bg-emerald-700 text-white font-medium px-6 py-2.5 rounded-xl transition-colors text-sm shadow-sm">موافق والعودة للمتجر</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>