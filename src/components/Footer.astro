---
// Footer — Pure Astro component, no JavaScript shipped to browser
const STORE_NAME = "متجري";
const currentYear = new Date().getFullYear();
const socialLinks = {
  facebook: "https://www.facebook.com/profile.php?id=61591983147698#",
  instagram: "https://instagram.com/yourprofile",
  whatsapp: "https://wa.me/213774422923",
};
---

<footer class="bg-white border-t border-gray-100 mt-auto" dir="rtl">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      
      <!-- Column 1: Brand Info -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2 font-bold text-lg text-gray-900">
          <div class="w-8 h-8 bg-emerald-50 rounded-lg flex items-center justify-center text-emerald-600">
            <!-- Shopping bag icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </div>
          <span>{STORE_NAME}</span>
        </a>
        <p class="text-sm text-gray-500 leading-relaxed max-w-sm">
          أفضل المنتجات بأفضل الأسعار مع التوصيل السريع إلى 58 ولاية والدفع عند الاستلام.
        </p>
        <div class="flex items-center gap-2 text-emerald-600 bg-emerald-50/50 px-3 py-1.5 rounded-xl text-xs font-semibold w-fit">
          <!-- Shield check icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <span>الدفع عند الاستلام مع معاينة المنتج</span>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="space-y-4">
        <h4 class="text-sm font-bold text-gray-900 tracking-wider">صفحات هامة</h4>
        <ul class="space-y-2.5 text-sm">
          <li>
            <a href="/" class="text-gray-500 hover:text-emerald-600 transition-colors">الرئيسية</a>
          </li>
          <li>
            <a href="/refund-policy" class="text-gray-500 hover:text-emerald-600 transition-colors">سياسة الإسترجاع و الإستبدال</a>
          </li>
          <li>
            <a href="/terms-conditions" class="text-gray-500 hover:text-emerald-600 transition-colors">الشروط والأحكام</a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Socials -->
      <div class="space-y-4">
        <h4 class="text-sm font-bold text-gray-900 tracking-wider">تابعنا على</h4>
        <div class="flex items-center gap-3">
          <a 
            href={socialLinks.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-xl bg-gray-50 flex items-center justify-center text-gray-500 hover:bg-blue-50 hover:text-blue-600 transition-all"
            title="Facebook"
          >
            <!-- Facebook icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a
            href={socialLinks.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-xl bg-gray-50 flex items-center justify-center text-gray-500 hover:bg-pink-50 hover:text-pink-600 transition-all"
            title="Instagram"
          >
            <!-- Instagram icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a
            href={socialLinks.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600 hover:bg-emerald-100 hover:scale-105 transition-all"
            title="WhatsApp"
          >
            <!-- WhatsApp icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Copyright -->
  <div class="bg-gray-50 py-6 border-t border-gray-100 text-center text-xs text-gray-400">
    <div class="max-w-5xl mx-auto px-4 flex flex-col sm:flex-row justify-between items-center gap-2">
      <p>&copy; {currentYear} {STORE_NAME}. جميع الحقوق محفوظة.</p>
      <p class="opacity-75">صنع بكل حب للتسوق الممتع والآمن</p>
    </div>
  </div>
</footer>